<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Main game screen.

    Layers (bottom → top):
      1. ImageView  — background.jpg covers the whole window
      2. Region     — semi-transparent dark overlay
      3. BorderPane — menu bar + icon toolbar on top; maze canvas fills the centre

    The maze canvas (MazeDisplayer) is added to mazeContainer programmatically
    in MyViewController.initialize() and is sized to fill the container.
-->
<StackPane fx:id="gameRoot"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="View.MyViewController">

    <!-- Layer 1: background photo -->
    <ImageView fx:id="gameBackgroundView" preserveRatio="false" smooth="true"/>

    <!-- Layer 2: dim overlay -->
    <Region styleClass="game-bg-overlay"/>

    <!-- Layer 3: game UI -->
    <BorderPane>

        <top>
            <VBox>
                <!-- Light-coloured menu bar (File / Options / Help) -->
                <MenuBar styleClass="game-menu-bar">
                    <Menu text="File">
                        <MenuItem text="New Maze"  onAction="#onNewMaze"/>
                        <MenuItem fx:id="menuSave" text="Save" onAction="#onSaveMaze" disable="true"/>
                        <MenuItem text="Load"      onAction="#onLoadMaze"/>
                        <MenuItem text="Exit"      onAction="#onExit"/>
                    </Menu>
                    <Menu text="Options">
                        <MenuItem text="Properties" onAction="#onProperties"/>
                    </Menu>
                    <Menu text="Help">
                        <MenuItem text="Help"  onAction="#onHelp"/>
                        <MenuItem text="About" onAction="#onAbout"/>
                    </Menu>
                </MenuBar>

                <!-- Icon toolbar — buttons centred in the bar -->
                <HBox styleClass="game-toolbar" alignment="CENTER" spacing="20">
                    <padding><Insets top="8" bottom="8" left="20" right="20"/></padding>

                    <!-- ✚ NEW MAZE -->
                    <Button fx:id="btnNewMaze" styleClass="toolbar-btn" onAction="#onNewMaze" focusTraversable="false">
                        <graphic>
                            <VBox alignment="CENTER" spacing="3">
                                <Label text="+" styleClass="toolbar-icon new-icon"/>
                                <Label text="new maze" styleClass="toolbar-text"/>
                            </VBox>
                        </graphic>
                    </Button>

                    <!-- 💾 SAVE (floppy disk) -->
                    <Button fx:id="btnSave" styleClass="toolbar-btn" onAction="#onSaveMaze"
                            disable="true" focusTraversable="false">
                        <graphic>
                            <VBox alignment="CENTER" spacing="3">
                                <Label text="💾" styleClass="toolbar-icon"/>
                                <Label text="save" styleClass="toolbar-text"/>
                            </VBox>
                        </graphic>
                    </Button>

                    <!-- ◎ LOAD (disc/CD shape) -->
                    <Button styleClass="toolbar-btn" onAction="#onLoadMaze" focusTraversable="false">
                        <graphic>
                            <VBox alignment="CENTER" spacing="3">
                                <Label text="◎" styleClass="toolbar-icon"/>
                                <Label text="load" styleClass="toolbar-text"/>
                            </VBox>
                        </graphic>
                    </Button>

                    <!-- ? SOLVE (pink circle) -->
                    <Button fx:id="btnSolve" styleClass="toolbar-btn" onAction="#onSolveMaze"
                            disable="true" focusTraversable="false">
                        <graphic>
                            <VBox alignment="CENTER" spacing="3">
                                <Label text="?" styleClass="toolbar-icon solve-icon"/>
                                <Label text="solve" styleClass="toolbar-text"/>
                            </VBox>
                        </graphic>
                    </Button>

                    <!-- ▶ MUSIC (play / pause — icon updated by controller) -->
                    <Button fx:id="btnSound" styleClass="toolbar-btn" onAction="#onToggleTrailSound"
                            focusTraversable="false">
                        <graphic>
                            <VBox alignment="CENTER" spacing="3">
                                <Label fx:id="soundIcon" text="▶" styleClass="toolbar-icon"/>
                                <Label text="music" styleClass="toolbar-text"/>
                            </VBox>
                        </graphic>
                    </Button>

                </HBox>
            </VBox>
        </top>

        <!-- Maze canvas — fills all remaining space -->
        <center>
            <StackPane fx:id="mazeContainer" styleClass="game-maze-container"/>
        </center>

        <!-- Status bar at the very bottom -->
        <bottom>
            <HBox spacing="20" styleClass="game-status-bar">
                <padding><Insets top="4" bottom="4" left="14" right="14"/></padding>
                <Label fx:id="mazeInfoLabel" styleClass="game-maze-info"/>
                <Label fx:id="statusLabel"   styleClass="game-status-label"/>
            </HBox>
        </bottom>

    </BorderPane>
</StackPane>
