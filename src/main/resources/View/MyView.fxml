<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Main screen layout for the maze desktop app.
    This file defines View controls only. Game logic stays in ViewModel and Model.
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="View.MyViewController">
    <top>
        <MenuBar>
            <Menu text="File">
                <MenuItem text="New" onAction="#onNewMaze"/>
                <MenuItem fx:id="menuSave" text="Save" onAction="#onSaveMaze" disable="true"/>
                <MenuItem text="Load" onAction="#onLoadMaze"/>
                <MenuItem text="Exit" onAction="#onExit"/>
            </Menu>
            <Menu text="Options">
                <MenuItem text="Properties" onAction="#onProperties"/>
            </Menu>
            <Menu text="Help">
                <MenuItem text="Help" onAction="#onHelp"/>
                <MenuItem text="About" onAction="#onAbout"/>
            </Menu>
        </MenuBar>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="14.0" styleClass="main-content">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
            </padding>

            <Label text="ATP Maze Game" styleClass="screen-title"/>
            <Label text="Generate or load a maze to start." styleClass="start-message"/>

            <HBox alignment="CENTER" spacing="10.0" styleClass="controls-row">
                <Label text="Rows" styleClass="field-label"/>
                <TextField fx:id="txtRows" text="20" prefWidth="80"/>
                <Label text="Columns" styleClass="field-label"/>
                <TextField fx:id="txtCols" text="20" prefWidth="80"/>
                <Button text="New Maze" onAction="#onNewMaze"/>
            </HBox>

            <HBox alignment="CENTER" spacing="10.0" styleClass="controls-row">
                <Button fx:id="btnSolve" text="Solve" onAction="#onSolveMaze" disable="true"/>
                <Button fx:id="btnSave" text="Save" onAction="#onSaveMaze" disable="true"/>
                <Button text="Load" onAction="#onLoadMaze"/>
                <Button fx:id="btnSound" text="Stop Music" onAction="#onToggleTrailSound"/>
            </HBox>

            <!-- The controller inserts the reusable MazeDisplayer canvas into this container. -->
            <StackPane fx:id="mazeContainer" styleClass="maze-container" prefWidth="620" prefHeight="420" maxWidth="Infinity" VBox.vgrow="ALWAYS"/>

            <Label fx:id="mazeInfoLabel" styleClass="maze-info"/>
            <Label fx:id="statusLabel" styleClass="status-label"/>
        </VBox>
    </center>
</BorderPane>
